@page "/gallery"
@using LittleHelpers.Service
@rendermode InteractiveServer
@inject IDatabaseService DatabaseService
@inject MudBlazor.IDialogService DialogService

<MudDialogProvider />

<MudText Typo="Typo.h5" Class="mb-4">Gallery</MudText>

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           Class="mb-4"
           OnClick="CreateMeal">
    Create Image
</MudButton>

<MudGrid>
    @foreach (var item in Meals)
    {
        <MudItem xs="6" sm="4" md="3">
             <MealCard meal="item" OnClick="@OpenDrawer" />
            </MudItem>
    }
</MudGrid>


<DetailsDrawer Open="@_drawerOpen"
               meal="SelectedMeal"
               OnClose="CloseDrawer"
               OnEdit="EditMeal" />

@code {

    List<Meal> Meals = [];

    protected override async Task OnParametersSetAsync()
    {
        await Task.Run(() => { _drawerOpen = false; });
    }

    protected override void OnInitialized()
    {
        Meals = DatabaseService.GetAllMealsAsync().Result;
    }

    bool _drawerOpen;
    Meal? SelectedMeal;

    async Task CreateMeal()
    {
        var parameters = new MudBlazor.DialogParameters
            {
                ["Model"] = new Meal()
            };

        var dialog = await DialogService.ShowAsync<MealFormDialog>("Create", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (model, file) = ((Meal, IBrowserFile?))result.Data;

            if (file != null && file.ContentType.StartsWith("image/"))
            {
                var stream = file.OpenReadStream(5 * 1024 * 1024);
                var ext = Path.GetExtension(file.Name);

                await DatabaseService.CreateMealAsync(model, stream, ext);
                Meals = await DatabaseService.GetAllMealsAsync();
            }
            else
            {

            }
        }
    }

    async Task EditMeal(Meal item)
    {
        var parameters = new MudBlazor.DialogParameters
            {
                ["Model"] = item
            };

        var dialog = await DialogService.ShowAsync<MealFormDialog>("Edit", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var updated = (Meal)result.Data;

            DatabaseService.Update(updated);
            Meals = DatabaseService.GetAllMealsAsync().Result;

            SelectedMeal = updated;
        }
    }

    void HandleClickMealCard(Meal meal)
    {
        SelectedMeal = meal;
        _drawerOpen = true;        
    }

    void OpenDrawer(Meal meal)
    {
        SelectedMeal = meal;
        _drawerOpen = true;
    }

    void CloseDrawer()
    {
        _drawerOpen = false;
    }
}