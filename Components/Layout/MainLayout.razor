@inherits LayoutComponentBase
@inject MudBlazor.IDialogService DialogService

<MudThemeProvider />
<MudSnackbarProvider />

<MudLayout>

    <MudAppBar>
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        Little Helpers
    </MudAppBar>

    
    <MudDrawer @bind-Open="@_open" Elevation="1" Variant="@DrawerVariant.Temporary" Anchor="Anchor.Left" OverlayAutoClose="true">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Little Helpers</MudText>
        </MudDrawerHeader>
        <NavMenu />  
    </MudDrawer>

    <!-- PAGE CONTENT -->
    <MudMainContent>

        <MudContainer MaxWidth="MaxWidth.ExtraLarge"
                      Class="mt-4">
            @Body
        </MudContainer>

    </MudMainContent>

</MudLayout>

@code {

    private bool _open = true;

    private void ToggleDrawer()
    {
        _open = !_open;
    }
}
