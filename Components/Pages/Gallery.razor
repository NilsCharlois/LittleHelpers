@page "/gallery"
@using LittleHelpers.Service
@rendermode InteractiveServer
@inject IMealService MealService
@inject MudBlazor.IDialogService DialogService
@inject NavigationManager NavigationManager

<MudDialogProvider />

<MudText Typo="Typo.h5" Class="mb-4"><MudIcon Icon="@Icons.Material.Outlined.Fastfood" Title="Meals" /> Meals <MudIcon Icon="@Icons.Material.Outlined.Fastfood" Title="Meals" /></MudText>

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           Class="mb-4"
           OnClick="CreateMeal">
    Add a meal idea
</MudButton>

<MudGrid>
    @foreach (var item in Meals)
    {
        <MudItem xs="6" sm="4" md="3">
             <MealCard meal="item" OnClick="@OpenDrawer" />
            </MudItem>
    }
</MudGrid>


<DetailsDrawer Open="@_drawerOpen" meal="SelectedMeal" OnClose="CloseDrawer" OnEdit="EditMeal" OnDelete="DeleteMeal" />

@code {

    List<Meal> Meals = [];

    protected override async Task OnParametersSetAsync()
    {
        await Task.Run(() => { _drawerOpen = false; });
    }

    protected override void OnInitialized()
    {
        Meals = MealService.GetAllMealsAsync().Result;
    }

    bool _drawerOpen;
    Meal? SelectedMeal;

    async Task CreateMeal()
    {
        var parameters = new MudBlazor.DialogParameters
            {
                ["Model"] = new Meal()
            };

        var dialog = await DialogService.ShowAsync<MealFormDialog>("Add a new meal", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (model, file) = ((Meal, IBrowserFile?))result.Data;

            if (file != null && file.ContentType.StartsWith("image/"))
            {
                var stream = file.OpenReadStream(5 * 1024 * 1024);
                var ext = Path.GetExtension(file.Name);

                await MealService.CreateMealAsync(model, stream, ext);
                Meals = await MealService.GetAllMealsAsync();
            }
            else
            {

            }
        }
    }

    async Task DeleteMeal(Meal item)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning", 
            "Delete the meal?", 
            yesText:"Delete!", cancelText:"Cancel");

        if (result.HasValue && result.Value)
        {
            MealService.Delete(item);

            NavigationManager.NavigateTo("/gallery", true);
        }
    }

    async Task EditMeal(Meal item)
    {
        var parameters = new MudBlazor.DialogParameters
            {
                ["Model"] = item
            };

        var dialog = await DialogService.ShowAsync<MealFormDialog>("Edit meal", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            var (model, file) = ((Meal, IBrowserFile?))result.Data;
            //var updated = (Meal)result.Data;
            if (file != null)
            {
                var stream =
                    file.OpenReadStream(5 * 1024 * 1024);

                var ext =
                    Path.GetExtension(file.Name);

                MealService.Update(
                    model,
                    stream,
                    ext);
            }
            else
            {
                MealService.Update(model);
            }

            Meals = MealService.GetAllMealsAsync().Result;

            SelectedMeal = model;
        }
    }

    void HandleClickMealCard(Meal meal)
    {
        SelectedMeal = meal;
        _drawerOpen = true;        
    }

    void OpenDrawer(Meal meal)
    {
        SelectedMeal = meal;
        _drawerOpen = true;
    }

    void CloseDrawer()
    {
        _drawerOpen = false;
    }
}