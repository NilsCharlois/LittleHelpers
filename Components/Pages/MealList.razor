@inject IDatabaseService DatabaseService
@page "/mealList"
@using LittleHelpers.Service
@rendermode InteractiveServer

<div style="display:flex ; flex-flow:row wrap">
@foreach (Meal meal in meals)
{
    <div class="col-sm-4 col-md-3 col-xs-6">
            <BlazorBootstrap.Card>
                <BlazorBootstrap.CardBody>
                    <BlazorBootstrap.CardTitle>@meal.Name</BlazorBootstrap.CardTitle>
                </BlazorBootstrap.CardBody>
                <BlazorBootstrap.Image Src="@meal.ImageUrl" IsThumbnail="true" Alt="placeholder" class="rounded-top" Style="width: 100%; height: 11vw; object-fit: cover;" />
            </BlazorBootstrap.Card>
    </div>
        
}
</div>


@code {
    private IEnumerable<Meal> meals = new List<Meal>();

    private HashSet<Meal> selectedMeals = new();

    private async Task<BlazorBootstrap.GridDataProviderResult<Meal>> MealsDataProvider(BlazorBootstrap.GridDataProviderRequest<Meal> request)
    {
        if (meals is null)
            meals = GetMeals();

        return await Task.FromResult(request.ApplyTo(meals));
    }

    protected override async Task OnInitializedAsync()
    {
        meals = GetMeals();
    }

    private IEnumerable<Meal> GetMeals()
    {
        return DatabaseService.GetAllMealsAsync().Result;
    }

    private Task OnSelectedItemsChanged(HashSet<Meal> meals)
    {
        selectedMeals = meals is not null && meals.Any() ? meals : new();
        return Task.CompletedTask;
    }
}